                         "dayjs":  "^1.11.10",
                         "dotenv":  "^16.3.1",
                         "express":  "^4.18.2",
                         "express-async-errors":  "^3.1.1",
                         "express-rate-limit":  "^7.1.5",
                         "helmet":  "^7.1.0",
                         "http-status-codes":  "^2.3.0",
                         "joi":  "^17.11.0",
                         "jsonwebtoken":  "^9.0.2",
                         "mongoose":  "^8.0.3",
                         "morgan":  "^1.10.0",
                         "multer":  "^1.4.5-lts.1",
                         "nodemailer":  "^8.0.5",
                         "pg":  "^8.11.3",
                         "pg-hstore":  "^2.3.4",
                         "sequelize":  "^6.35.2",
                         "uuid":  "^9.0.0",
                         "winston":  "^3.11.0",
                         "winston-daily-rotate-file":  "^4.7.1"
                     },
    "devDependencies":  {
                            "eslint":  "^8.55.0",
                            "jest":  "^29.7.0",
                            "nodemon":  "^3.0.2",
                            "supertest":  "^6.3.3"
                        },
    "jest":  {
                 "testEnvironment":  "node",
                 "testMatch":  [
                                   "**/tests/**/*.test.js"
                               ]
             }
}
