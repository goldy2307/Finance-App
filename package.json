{
    "name":  "cashly-finance-api",
    "version":  "1.0.0",
    "description":  "Cashly Finance â€” REST API (Node.js + Express + MongoDB/PostgreSQL)",
    "main":  "src/server.js",
    "engines":  {
                    "node":  "\u003e=18.0.0"
                },
    "scripts":  {
                    "start":  "node src/server.js",
                    "dev":  "nodemon src/server.js",
                    "test":  "jest --runInBand --forceExit",
                    "test:unit":  "jest tests/unit --runInBand",
                    "test:int":  "jest --testPathPattern=tests/integration --runInBand",
                    "lint":  "eslint src/**/*.js",
                    "migrate":  "node src/db/migrations/runner.js up",
                    "migrate:down":  "node src/db/migrations/runner.js down",
                    "create:admin":  "node src/scripts/create-admin.js"
                },
    "dependencies":  {
                         "bcryptjs":  "^2.4.3",
