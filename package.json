{
  "name": "cashly-finance-backend",
  "version": "1.0.0",
  "description": "Cashly Finance — Node.js/Express backend with DB-agnostic adapter layer",
  "main": "src/server.js",
  "scripts": {
    "start":     "node src/server.js",
    "dev":       "nodemon src/server.js",
    "test":      "jest --runInBand --forceExit",
    "test:unit": "jest tests/unit --runInBand",
    "test:int":  "jest tests/integration --runInBand",
    "lint":      "eslint src/**/*.js",
    "migrate":   "node src/db/migrations/run.js"
  },
  "dependencies": {
    "bcryptjs":                  "^2.4.3",
    "compression":               "^1.7.4",
    "cors":                      "^2.8.5",
    "dotenv":                    "^16.4.5",
    "express":                   "^4.18.3",
    "express-rate-limit":        "^7.2.0",
    "helmet":                    "^7.1.0",
    "joi":                       "^17.12.2",
    "jsonwebtoken":              "^9.0.2",
    "mongoose":                  "^8.3.4",
    "morgan":                    "^1.10.0",
    "pg":                        "^8.11.5",
    "sequelize":                 "^6.37.3",
    "uuid":                      "^9.0.1",
    "winston":                   "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "eslint":        "^9.2.0",
    "jest":          "^29.7.0",
    "nodemon":       "^3.1.0",
    "supertest":     "^7.0.0"
  },
  "jest": {
    "testEnvironment":     "node",
    "coverageDirectory":   "coverage",
    "collectCoverageFrom": ["src/**/*.js"]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}